rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: true if the authenticated user is in the allowed-users list.
    function isAllowedUser() {
      return request.auth != null
        && exists(/databases/$(database)/documents/allowedUsers/$(request.auth.uid));
    }

    // Allowlist: each doc id is a Firebase Auth UID. Users can only read their
    // own doc (so the app can check "am I allowed?"). Add/remove allowed users
    // via Firebase Console, Admin SDK, or the approve endpoint.
    match /allowedUsers/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Jobs: public reads, writes require allowlist.
    // SOLO-DEV (Plan 2): the unauthenticated Flutter desktop worker bumps
    // `completedSimCount` on the parent job after each successful sim. Tighten
    // to `if isAllowedUser()` once Plan 3 enables auth in the worker.
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isAllowedUser();
      allow update: if isAllowedUser()
        || (request.auth == null
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['completedSimCount']));
      allow delete: if isAllowedUser();

      // Per-simulation tracking subcollection: public reads.
      // SOLO-DEV (Plan 2): Flutter worker claims PENDING sims and writes
      // terminal results without auth. Creates/deletes still go through the
      // API. Tighten once Plan 3 enables auth.
      match /simulations/{simId} {
        allow read: if true;
        allow create, delete: if isAllowedUser();
        allow update: if isAllowedUser() || request.auth == null;
      }
    }

    // Unified decks collection: public reads
    // Only deck owner can delete; precons (ownerId == null) cannot be deleted by any user
    match /decks/{deckId} {
      allow read: if true;
      allow create: if isAllowedUser() && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isAllowedUser() && resource.data.ownerId == request.auth.uid;
      allow update: if false;
    }

    // Access requests: any authenticated user can create, users can read their own
    match /accessRequests/{requestId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Workers collection: public reads (worker status).
    // SOLO-DEV (Plan 2): the unauthenticated Flutter desktop worker writes its
    // own status/lease doc (workerType == 'flutter'). Other writes still go
    // through Admin SDK. Tighten once Plan 3 enables auth in the worker.
    match /workers/{workerId} {
      allow read: if true;
      allow create, update: if isAllowedUser()
        || (request.auth == null && request.resource.data.workerType == 'flutter');
      allow delete: if isAllowedUser();
    }

    // Catch-all: deny everything else not explicitly matched
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
