<?xml version="1.0" encoding="utf-8"?>
<!--
  Sparkle appcast for Magic Bracket Simulator desktop worker.

  Fetched at runtime from this file on `main`:
    https://raw.githubusercontent.com/TytaniumDev/MagicBracketSimulator/main/worker_flutter/appcast.xml

  This file is updated automatically by .github/workflows/release-worker.yml
  on every release. On each main push the workflow:
    1. Auto-tags a `worker-v*` version (bumps patch).
    2. Builds + signs + notarizes the macOS app, signs the Windows zip.
    3. Publishes the GitHub Release with the signed artifacts.
    4. Prepends a new <item> to this file (with the EdDSA signature
       pulled from the build's sparkle-manifest.json) and commits the
       change back to main.

  Sparkle picks the highest sparkle:version and offers it as the update.
  The host app's SUPublicEDKey in Info.plist verifies every signature.
-->
<rss version="2.0" xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle">
  <channel>
    <title>Magic Bracket Simulator</title>
    <description>Desktop worker for the Magic Bracket Simulator project.</description>
    <language>en</language>

    <!-- Windows (WinSparkle) — separate entries for Windows updates
         will land here once the Windows update flow is verified
         end-to-end. The Windows zip is signed (DSA) on every release
         and attached to the GitHub Release as
         `worker_flutter-windows.zip`, but adding Windows <item> entries
         to this feed is deferred until a Windows install is confirmed
         to install + relaunch cleanly via WinSparkle. -->
  </channel>
</rss>
