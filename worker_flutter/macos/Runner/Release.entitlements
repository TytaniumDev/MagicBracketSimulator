<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sandbox disabled because we spawn a child Java process from a
	     downloaded JRE outside the .app bundle. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>

	<!-- Network access for the first-run installer + log upload. -->
	<key>com.apple.security.network.client</key>
	<true/>

	<!-- Hardened runtime concessions required by the bundled JVM:
	     - allow-jit: HotSpot generates JIT'd machine code at runtime.
	     - allow-unsigned-executable-memory: HotSpot writes executable
	       memory that isn't signed.
	     - disable-library-validation: lets the JVM load JNI dylibs
	       (libjli, libjvm, etc.) whose Team ID differs from ours.
	     Without these, the notarized app crashes on first Java spawn. -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>

	<!-- Firebase Auth on macOS persists the signed-in session through
	     SecItemAdd/Update. With sandbox disabled + hardened runtime,
	     macOS 26 (Tahoe) returns errSecMissingEntitlement (-34018) on
	     those calls unless the app declares a keychain access group,
	     surfaced to Dart as [firebase_auth/keychain-error]. The single
	     entry here is the app's own per-bundle-id keychain group
	     (the $(AppIdentifierPrefix) prefix expands to "<Team ID>." at
	     codesign time — F2HXQGU2CC for our Developer ID). Firebase Auth
	     uses this first entry as its default access group. -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.tytaniumdev.magicBracketSimulator</string>
	</array>
</dict>
</plist>
