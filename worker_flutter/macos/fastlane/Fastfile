# Fastlane config for the Magic Bracket worker (macOS) — Developer ID
# signing + Apple notarization. Adapted from the BlinkBreak iOS pattern.
#
# Locally (one-time setup, requires manual Developer ID cert creation):
#   1. Create a "Developer ID Application" cert in the Apple Developer
#      portal for team F2HXQGU2CC.
#   2. Run `bundle exec fastlane seed_certs` to seed the cert/profile
#      into the TytaniumDev-certificates git repo.
#   3. From CI, the `release` lane below uses `sync_certs` (readonly)
#      to install the cert + profile into an ephemeral keychain.
#
# Required env vars (CI):
#   MATCH_PASSWORD             - AES key for the certs repo
#   MATCH_KEYCHAIN_PASSWORD    - password for the ephemeral keychain
#   ASC_KEY_ID                 - App Store Connect API key ID
#   ASC_ISSUER_ID              - App Store Connect issuer ID
#   ASC_API_KEY_CONTENT        - contents of the AuthKey_*.p8 file
#   ASC_API_KEY_IS_BASE64      - "true" if ASC_API_KEY_CONTENT is base64
#
# Locally: set the same env vars (or use `doppler run --`).

default_platform(:mac)

APP_IDENTIFIER = "com.tytaniumdev.magicBracketSimulator".freeze
TEAM_ID        = "F2HXQGU2CC".freeze
XCODEPROJ      = "Runner.xcodeproj".freeze
SCHEME         = "Runner".freeze

def asc_api_key
  app_store_connect_api_key(
    key_id:                ENV.fetch("ASC_KEY_ID"),
    issuer_id:             ENV.fetch("ASC_ISSUER_ID"),
    key_content:           ENV.fetch("ASC_API_KEY_CONTENT"),
    is_key_content_base64: ENV["ASC_API_KEY_IS_BASE64"] == "true",
    in_house:              false
  )
end

platform :mac do
  desc "Seed the match certs repo with a Developer ID Application cert + profile (run once locally)"
  lane :seed_certs do
    match(
      api_key:        asc_api_key,
      git_url:        "git@github.com:TytaniumDev/TytaniumDev-certificates.git",
      storage_mode:   "git",
      type:           "developer_id",
      app_identifier: [APP_IDENTIFIER],
      platform:       "macos",
      readonly:       false,
      force_for_new_devices: false
    )
  end

  desc "Install signing assets from match (read-only)"
  lane :sync_certs do
    if is_ci
      create_keychain(
        name:              "magic-bracket-worker.keychain",
        password:          ENV.fetch("MATCH_KEYCHAIN_PASSWORD"),
        default_keychain:  true,
        unlock:            true,
        timeout:           3600,
        lock_when_sleeps:  false
      )
    end

    match(
      api_key:        asc_api_key,
      git_url:        "git@github.com:TytaniumDev/TytaniumDev-certificates.git",
      storage_mode:   "git",
      type:           "developer_id",
      app_identifier: [APP_IDENTIFIER],
      platform:       "macos",
      readonly:       true,
      keychain_name:     is_ci ? "magic-bracket-worker.keychain" : nil,
      keychain_password: is_ci ? ENV.fetch("MATCH_KEYCHAIN_PASSWORD") : nil
    )
  end

  desc "Build, sign, and notarize the macOS Flutter app for outside-MAS distribution"
  lane :release do
    sync_certs

    update_code_signing_settings(
      path:                  XCODEPROJ,
      use_automatic_signing: false,
      targets:               ["Runner"],
      team_id:               TEAM_ID,
      code_sign_identity:    "Developer ID Application",
      profile_name:          "match Direct #{APP_IDENTIFIER} macos",
      bundle_identifier:     APP_IDENTIFIER
    )

    # Flutter release build. The Xcode project's Release config uses the
    # signing identity match just installed.
    #
    # `with_unbundled_env` is critical: `bundle exec fastlane` exports
    # GEM_PATH, RUBYOPT, etc. pointing at fastlane's bundle. Without
    # clearing those, Flutter's child `pod` invocation tries to load
    # cocoapods from the fastlane bundle (where it isn't), and aborts
    # with "CocoaPods is installed but broken. Skipping pod install."
    # mid-build. The brew-installed pod expects to run in a vanilla
    # env where its own Ruby + gems resolve cleanly.
    Bundler.with_unbundled_env do
      # GOOGLE_DESKTOP_OAUTH_CLIENT_SECRET is forwarded into the
      # binary at build time via --dart-define. CI gets it from
      # Doppler (blinkbreak/prd); local dev needs to set the same
      # env var, e.g. via `doppler run -- bundle exec fastlane release`.
      desktop_secret = ENV.fetch("GOOGLE_DESKTOP_OAUTH_CLIENT_SECRET", "")
      # Sentry DSN + release metadata travel the same path. Empty
      # values turn Sentry into a no-op, which is what local builds
      # want until an operator wires the new project up.
      sentry_dsn     = ENV.fetch("SENTRY_DSN_WORKER", "")
      sentry_release = ENV.fetch("SENTRY_RELEASE", "worker_flutter@dev")
      git_sha        = ENV.fetch("GITHUB_SHA", "local")
      # `--obfuscate --split-debug-info` is what makes sentry_dart_plugin
      # useful: it strips Dart symbols from the binary and writes the
      # symbol map to build/debug-info/macos. The plugin then uploads
      # that map so stack traces in Sentry deobfuscate.
      sh(
        "cd ../.. && flutter build macos --release " \
        "--obfuscate --split-debug-info=build/debug-info/macos " \
        "--dart-define=GOOGLE_DESKTOP_OAUTH_CLIENT_SECRET=#{desktop_secret.shellescape} " \
        "--dart-define=SENTRY_DSN=#{sentry_dsn.shellescape} " \
        "--dart-define=SENTRY_RELEASE=#{sentry_release.shellescape} " \
        "--dart-define=GIT_SHA=#{git_sha.shellescape}"
      )
    end

    # Resolve the .app path absolutely — fastlane's CWD when executing
    # actions varies (Fastfile dir vs invocation dir), and `File.exist?`
    # checks against Ruby's CWD, so a relative path silently fails the
    # codesign loop below.
    flutter_root_abs = File.expand_path('../..', __dir__)
    app_path_abs = File.join(flutter_root_abs, 'build/macos/Build/Products/Release/worker_flutter.app')
    # Keep a relative form for the fastlane `notarize` action so its
    # internal logic stays unchanged.
    app_path = "../build/macos/Build/Products/Release/worker_flutter.app"

    # Sparkle's embedded Updater.app, Autoupdate binary, and XPCServices
    # don't pick up the Hardened Runtime + secure timestamp from Flutter's
    # default "Embed & Sign" pass, so notarization rejects the package
    # with "binary is not signed with a valid Developer ID certificate."
    # Walk the framework and re-sign every nested executable with the
    # Developer ID identity that match just installed, then re-sign the
    # framework + outer .app on top so the seal includes the updated
    # nested signatures.
    sign_id = "Developer ID Application: Tyler Holland (#{TEAM_ID})"
    sparkle_root = "#{app_path_abs}/Contents/Frameworks/Sparkle.framework"
    UI.message("Deep-signing Sparkle.framework at #{sparkle_root}")
    UI.user_error!("Sparkle.framework not found at #{sparkle_root}") unless Dir.exist?(sparkle_root)
    [
      "#{sparkle_root}/Versions/B/Autoupdate",
      "#{sparkle_root}/Versions/B/Updater.app/Contents/MacOS/Updater",
      "#{sparkle_root}/Versions/B/Updater.app",
      "#{sparkle_root}/Versions/B/XPCServices/Installer.xpc/Contents/MacOS/Installer",
      "#{sparkle_root}/Versions/B/XPCServices/Installer.xpc",
      "#{sparkle_root}/Versions/B/XPCServices/Downloader.xpc/Contents/MacOS/Downloader",
      "#{sparkle_root}/Versions/B/XPCServices/Downloader.xpc",
      sparkle_root,
      app_path_abs,
    ].each do |target|
      unless File.exist?(target)
        UI.message("Skipping #{target} — not present")
        next
      end
      sh("codesign --force --options runtime --timestamp --sign #{sign_id.shellescape} #{target.shellescape}")
    end

    # Notarize the signed .app, then staple the ticket so users without
    # network at first launch don't see the unsigned warning.
    notarize(
      package:      app_path,
      bundle_id:    APP_IDENTIFIER,
      api_key:      asc_api_key,
      use_notarytool: true,
      print_log:    true
    )

    # Zip for distribution. The stapled .app inside the zip is what users
    # download. Use absolute paths so fastlane's `sh` working-directory
    # quirks don't bite.
    flutter_root = File.expand_path('../..', __dir__)
    release_dir = File.join(flutter_root, 'build/macos/Build/Products/Release')
    zip_path = File.join(flutter_root, 'build/worker_flutter-macos.zip')
    FileUtils.rm_f(zip_path)
    Dir.chdir(release_dir) do
      sh("zip -ry #{zip_path.shellescape} worker_flutter.app")
    end
  end
end
